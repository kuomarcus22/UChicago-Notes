global !p
def math():
	return vim.eval('vimtex#syntax#in_mathzone()') == '1'

def notmath():
	return vim.eval('vimtex#syntax#in_mathzone()') == '0'

def comment(): 
	return vim.eval('vimtex#syntax#in_comment()') == '1'

def env(name):
	[x,y] = vim.eval("vimtex#env#is_inside('" + name + "')") 
	return x != '0' and y != '0'

endglobal

snippet hw_template "Homework template" b
% This template originates from:
% http://www.LaTeXTemplates.com
%
% Author:
% Vel (vel@LaTeXTemplates.com)
%
% License:
% CC BY-NC-SA 3.0 (http://creativecommons.org/licenses/by-nc-sa/3.0/)
% 
%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%%

%----------------------------------------------------------------------------------------
%	PACKAGES AND OTHER DOCUMENT CONFIGURATIONS
%----------------------------------------------------------------------------------------

\documentclass[11pt]{article}

\input{~/Documents/UChicago/shared/latex/hw_structure.tex} % Include the file specifying the document structure and custom commands

\renewcommand{\subqnumbering}{\alph} % redefines subsection numbering. Options: \arabic for 1,2,3; \roman for i,ii,iii; \alph for a,b,c

\relpenalty=10000
\binoppenalty=10000

%----------------------------------------------------------------------------------------
%	ASSIGNMENT INFORMATION
%----------------------------------------------------------------------------------------

% Required
\newcommand{\assignmentQuestionName}{Exercise} % The word to be used as a prefix to question numbers; example alternatives: Problem, Exercise
\newcommand{\assignmentClass}{$1} % Course/class
\newcommand{\assignmentTitle}{$2} % Assignment title or name
\newcommand{\assignmentAuthorName}{Marcus Kuo} % Student name

%----------------------------------------------------------------------------------------

\begin{document}

%----------------------------------------------------------------------------------------
%	TITLE PAGE
%----------------------------------------------------------------------------------------

% \maketitle % Print the title page

% \thispagestyle{empty} % Suppress headers and footers on the title page

% \newpage

%----------------------------------------------------------------------------------------
%	QUESTION 1
%----------------------------------------------------------------------------------------

\begin{question}

	\questiontext{$3}	

\end{question}

\end{document}
endsnippet

