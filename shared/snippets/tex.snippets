snippet tufte_lecnotes_template "Tufte Lecture Notes Template" b
\documentclass{tufte-handout}

\title{$1}

\author{Marcus Kuo}

\date{\today$2} % without \date command, current date is supplied

%\geometry{showframe} % display margins for debugging page layout

\usepackage{lastpage} % Required to determine the last page number for the footer
\usepackage{enumerate}
\usepackage{amssymb}
\usepackage{verbatim}
\usepackage{mathrsfs}
\usepackage[most]{tcolorbox} % Required for boxes that split across pages
\usepackage{booktabs} % Required for better horizontal rules in tables
\usepackage{listings} % Required for insertion of code
\usepackage{etoolbox} % Required for if statements
\usepackage{mathrsfs}
\usepackage{amssymb}
\usepackage{capt-of}
\usepackage{soul}
\usepackage{pdfpages}
\usepackage{xcolor}
\usepackage{hyperref}
\usepackage{graphicx} % allow embedded images
\setkeys{Gin}{width=\linewidth,totalheight=\textheight,keepaspectratio}
\graphicspath{{}} % set of paths to search for images
\usepackage{amsmath}  % extended mathematics
\usepackage{booktabs} % book-quality tables
\usepackage{units}    % non-stacked fractions and better unit spacing
\usepackage{multicol} % multiple column layout facilities
\usepackage{lipsum}   % filler text
\usepackage{fancyvrb} % extended verbatim environments
\fvset{fontsize=\normalsize}% default font size for fancy-verbatim environments
\usepackage{amsthm}
\usepackage{mathtools}
\usepackage{comment}
\usepackage{dsfont}

% Standardize command font styles and environments
\newcommand{\doccmd}[1]{\texttt{\textbackslash#1}}% command name -- adds backslash automatically
\newcommand{\docopt}[1]{\ensuremath{\langle}\textrm{\textit{#1}}\ensuremath{\rangle}}% optional command argument
\newcommand{\docarg}[1]{\textrm{\textit{#1}}}% (required) command argument
\newcommand{\docenv}[1]{\textsf{#1}}% environment name
\newcommand{\docpkg}[1]{\texttt{#1}}% package name
\newcommand{\doccls}[1]{\texttt{#1}}% document class name
\newcommand{\docclsopt}[1]{\texttt{#1}}% document class option name

\newcommand{\ind}{\perp\!\!\!\perp} 
\newcommand*\N{\mathbb{N}}
\newcommand*\R{\mathbb{R}}
\newcommand*\Q{\mathbb{Q}}
\newcommand*\Z{\mathbb{Z}}
\newcommand*\E{\mathbb{E}}
\let\oldP\P
\renewcommand*\P{\mathbb{P}}
\let\O\varnothing
\let\oldemptyset\emptyset
\let\emptyset\varnothing

\DeclareMathOperator*{\argmax}{arg\,max} % thin space, limits underneath in displays
\DeclareMathOperator*{\argmin}{arg\,min} % thin space, limits underneath in displays

\newenvironment{docspec}{\begin{quote}\noindent}{\end{quote}}% command specification environment

\newtheorem{thm}{Theorem}[subsection]
\newtheorem{lemma}[thm]{Lemma}
\newtheorem{cor}[thm]{Corollary}
\newtheorem{rmk}[thm]{Remark}
\newtheorem{conj}[thm]{Conjecture}
\newtheorem{ex}[thm]{Example}
\newtheorem{aside}[thm]{Aside}
\newtheorem{notation}[thm]{Notation}
\newtheorem{prop}[thm]{Proposition}

\theoremstyle{definition}
\newtheorem{defn}[thm]{Definition}

\setcounter{secnumdepth}{2}
\setcounter{tocdepth}{1}

\relpenalty=10000
\binoppenalty=10000

\begin{document}

\maketitle
\tableofcontents

\newpage

\section{$3}\label{$4}
\subsection{$5}

$0

\end{document}
endsnippet

snippet lecnotes_template "lecnotes template"
\input{../../shared/latex/notes_preamble.tex}

\renewcommand{\notesauthor}{Marcus Kuo}
\renewcommand{\notesyear}{${1:Quarter}}

\setcounter{secnumdepth}{2}
\setcounter{tocdepth}{1}

\begin{document}

\makelectitle{${2:Course Number} \\ \vspace{0.2em} ${3:Course Name}}{${1: Quarter}}{Marcus Kuo \\ \small{Lectures by ${4: Instructor}}}
\tableofcontents
\clearpage

\input{chapters/${4:first_chapter}}
endsnippet

snippet ntt "newthought" bA
\newthought{$1} $0
endsnippet

snippet ntsl "newthought solution" bA
\newthought{Solution.} $0
endsnippet

snippet mnn "margin note" iA
\marginnote{$1}$0
endsnippet

snippet fnn "footnote" iA
\footnote{$1}$0
endsnippet

snippet bnn "boxed note" iA
\boxednote{$1}$0
endsnippet

context "math()"
snippet ee "expected value" iA
\E\left[$1\right] $0
endsnippet

context "math()"
snippet ete "expected value at t" iA
\E_t\left[$1\right] $0
endsnippet

context "math()"
snippet E_E "expected value at _" iA
\E_{$1}\left[$2\right] $0
endsnippet

context "math()"
snippet Epe "expected value at p" iA
\E_p\left[$1\right] $0
endsnippet

context "math()"
snippet PP "probability" iA
\P\left[$1\right] $0
endsnippet

context "math()"
snippet P_P "probability at _" iA
\P_{$1}\left[$2\right] $0
endsnippet

priority 10
context "math()"
snippet qd "quad" iA
\quad$0
endsnippet

priority 100
context "math()"
snippet qqd "qquad" iA
\qquad$0
endsnippet

snippet red "text color red" iw
\textcolor{red}{$1} $0
endsnippet

snippet blue "text color blue" iw
\textcolor{blue}{$1} $0
endsnippet

context "math()"
snippet coss "cos squared" i
\cos^2{($1)} $0
endsnippet

context "math()"
snippet sins "sin squared" i
\sin^2{($1)} $0
endsnippet

snippet codeblock "code block" b
\begin{unnumberedquestion}
	\questiontext{\textbf{$1}}
	\answer{
		\lstinputlisting[language=Matlab, basicstyle=\ttfamily\small,showspaces=false,showstringspaces=false]{~/Documents/MATLAB/$2}
	}
\end{unnumberedquestion}
$0
endsnippet

context "math()"
snippet opn "operatorname" iA
\operatorname{$1}$0
endsnippet

context "math()"
snippet exp "exponential" w
\exp\left($1\right)$0
endsnippet

context "math()"
snippet Var "variance" w
\Var\left($1\right)$0
endsnippet

context "math()"
snippet Cov "covariance" w
\Cov\left($1\right)$0
endsnippet

context "math()"
snippet Corr "correlation" w
\Corr\left($1\right)$0
endsnippet

context "math()"
snippet Bias "bias" w
\Bias\left($1\right)$0
endsnippet

context "math()"
snippet MSE "mean squared error" w
\MSE\left($1\right)$0
endsnippet

context "math()"
snippet xra "xrightarrow" iA
\xrightarrow{$1}$0
endsnippet

priority 100
context "math()"
snippet "([a-zA-Z])circ" "circ" riA
\mathring{`!p snip.rv=match.group(1)`}
endsnippet

snippet ecount "enumcount" iA
\setcounter{enumi}{$1}$0
endsnippet

context "math()"
snippet '(?<!\\)(cap|cup)\b' "cap, cup" rA
`!p snip.rv = '\\' + match.group(1)`
endsnippet

snippet emph "emph" iA
\emph{$1}$0
endsnippet

snippet sec	"section" b
\section{$1}
$0
endsnippet

snippet subsec "subsection" b
\subsection{$1}
$0
endsnippet

context "math()"
snippet "wivar" "widehatvar" wA
\widehat{\operatorname{Var}}\left($1\right)$0
endsnippet

snippet notemarginnote "boxed margin note" b
\boxednote{$1}$0
endsnippet

snippet notefootnote "footnote" b
\footnote{$1}$0
endsnippet

snippet image "note image" b
\begin{figure}[${1:htpb}]
\centering
\caption{${2:Caption}}
\label{fig:${3:label}}
\includegraphics[width=0.78\textwidth]{images/${4:filename}}
\fignote{${5:Notes.}}
\end{figure}
$0
endsnippet

snippet mimage "margin image" b
\marginimage[${1:caption}]{${2:path from images}}
endsnippet

snippet 2image "two figures side by side: caption above, fignote below" b
\begin{figure}[${1:htpb}]
\centering
\caption{${2:Caption}}
\label{fig:${3:label}}
\begin{minipage}{0.48\textwidth}
  \centering
  \includegraphics[width=\textwidth]{images/${4:file1}}
\end{minipage}
\hfill
\begin{minipage}{0.48\textwidth}
  \centering
  \includegraphics[width=\textwidth]{images/${5:file2}}
\end{minipage}
\fignote{${6:Notes.}}
\end{figure}
$0
endsnippet

snippet thm "theorem environment" b
\begin{theorem}[${1:Title}]
	$2
\end{theorem}
$0
endsnippet

snippet prop "proposition environment" b
\begin{proposition}[${1:Title}]
	$2
\end{proposition}
$0
endsnippet

snippet lem "lemma environment" b
\begin{lemma}[${1:Title}]
	$2
\end{lemma}
$0
endsnippet

snippet cor "corollary environment" b
\begin{corollary}[${1:Title}]
	$2
\end{corollary}
$0
endsnippet

snippet defn "definition environment" b
\begin{definition}[${1:Title}]
	$2
\end{definition}
$0
endsnippet

snippet ex "example environment" b
\begin{example}[${1:Title}]
	$2
\end{example}
$0
endsnippet

snippet asm "assumption environment" b
\begin{assumption}[${1:Title}]
	$2
\end{assumption}
$0
endsnippet

snippet notat "notation environment" b
\begin{notation}[${1:Title}]
	$2
\end{notation}
$0
endsnippet

snippet rmk "remark environment" b
\begin{remark}
$1
\end{remark}
$0
endsnippet

snippet aside "aside environment" b
\begin{aside}
$1
\end{aside}
$0
endsnippet

snippet prf "proof environment" b
\begin{proof}
	$1
\end{proof}
$0
endsnippet

snippet chapter "styled chapter" b
\styledchapter{$1}
$0
endsnippet

snippet rcode "R code block" b
\begin{rcodebox}
$1
\end{rcodebox}
$0
endsnippet
