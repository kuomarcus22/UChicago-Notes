snippet b2image "two images side by side" b
\begin{center}
  \begin{minipage}{0.49\textwidth}
    \includegraphics[width=\textwidth]{images/$1}
    \captionof{figure}{$2}
  \end{minipage}
  \hfill
  \begin{minipage}{0.49\textwidth}
    \includegraphics[width=\textwidth]{images/$3}
    \captionof{figure}{$4}
  \end{minipage}
\end{center}
endsnippet

